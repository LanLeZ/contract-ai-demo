# MySQL数据库配置
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=contract_ai

# JWT密钥（生产环境请修改为强密钥）
SECRET_KEY=your-secret-key-change-this-in-production-use-a-random-string

# 通义千问API配置（第3天新增）
# Embedding模型配置（可选，默认使用 qwen3-embedding-8b）
# EMBEDDING_MODEL=qwen3-embedding-8b
# 支持的模型：qwen3-embedding-8b, text-embedding-v3, text-embedding-v2, text-embedding-v4

# 方式1：使用中转平台API（推荐，如果使用中转平台）
# EMBEDDING_API_BASE_URL=https://your-proxy-api-endpoint.com/v1/embeddings
# EMBEDDING_API_KEY=your-proxy-api-key-here

# 方式2：使用DashScope SDK（直接使用阿里云API）
# 获取方式：访问 https://dashscope.console.aliyun.com/ 创建API Key
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 向量库配置（第3天新增）
# 持久化目录路径，用于存储向量数据
# 如果需要保留旧向量库，可以修改为不同的路径，例如：./chroma_db_v2
CHROMA_PERSIST_DIR=./chroma_db

