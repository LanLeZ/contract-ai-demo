{
    "contract_type": "租房合同",
    "description": "本模板定义了租房合同知识抽取的实体类型和关系类型，每个关系明确了头实体类型和尾实体类型，用于指导三元组（头实体-关系-尾实体）的抽取。",
    "entities": [
        "出租人",
        "承租人",
        "房屋地址",
        "租赁期限",
        "租金",
        "押金",
        "付款方式",
        "费用承担",
        "维修责任",
        "违约责任",
        "房屋用途",
        "设施物品清单",
        "转租约定",
        "交付日期"
    ],
    "relations": [
        {
            "relation": "出租给",
            "definition": "出租人将房屋出租给承租人，双方建立租赁关系",
            "head_entity_type": "出租人",
            "tail_entity_type": "承租人",
            "triggers": ["出租", "租给", "租赁", "承租"],
            "examples": [
                "甲方将房屋出租给乙方使用",
                "出租人同意将房屋租赁给承租人"
            ]
        },
        {
            "relation": "租赁房屋地址",
            "definition": "承租人租赁出租人的房屋，房屋地址为具体地点",
            "head_entity_type": "承租人",
            "tail_entity_type": "房屋地址",
            "triggers": ["房屋地址", "租赁房屋", "位于", "坐落"],
            "examples": [
                "该房屋坐落于佛山市南海区狮山镇",
                "房屋地址为广州市天河区体育西路"
            ]
        },
        {
            "relation": "支付租金",
            "definition": "承租人向出租人支付房屋租金，租金金额在租金实体中记录",
            "head_entity_type": "承租人",
            "tail_entity_type": "租金",
            "triggers": ["租金", "月租金", "每月租金", "人民币", "租赁费用"],
            "examples": [
                "该房屋月租金为(人民币大写)壹千柒百元整。",
                "甲乙双方议定月租金(人民币)2000元(大写两千元)。"
            ]
        },
        {
            "relation": "支付押金",
            "definition": "承租人向出租人支付押金作为履约保证，押金金额在押金实体中记录",
            "head_entity_type": "承租人",
            "tail_entity_type": "押金",
            "triggers": ["押金", "保证金", "押金金额", "支付押金"],
            "examples": [
                "自本合同签订之日起，由乙方支付甲方壹千元作为押金。",
                "乙方向甲方交纳押金(人民币)1500元(大写一千五百元)。"
            ]
        },
        {
            "relation": "约定租赁期限",
            "definition": "承租人与出租人约定的房屋租赁起止日期",
            "head_entity_type": "承租人",
            "tail_entity_type": "租赁期限",
            "triggers": ["租赁期限", "自", "至", "租期", "租赁期"],
            "examples": [
                "租赁期限自2021年3月1日至2025年3月1日止。",
                "该房屋租赁期自2022年9月1日起至2024年6月15日止。"
            ]
        },
        {
            "relation": "约定付款方式",
            "definition": "承租人支付租金的周期或具体方式",
            "head_entity_type": "承租人",
            "tail_entity_type": "付款方式",
            "triggers": ["支付", "租金支付", "一次性付清", "按...支付", "付款方式"],
            "examples": [
                "租金一次性付清。",
                "乙方按季度支付租金给甲方。"
            ]
        },
        {
            "relation": "承租人承担费用",
            "definition": "承租人在租赁期间需承担的费用项目，具体内容在费用承担实体中记录",
            "head_entity_type": "承租人",
            "tail_entity_type": "费用承担",
            "triggers": ["水费", "电费", "燃气费", "物业费", "承担", "费用"],
            "examples": [
                "在房屋租赁期间，乙方负责支付产生的水费、电费、燃气费、物业费等费用。",
                "以下费用由乙方支付：1.水、电费；2.煤气费；"
            ]
        },
        {
            "relation": "出租人承担费用",
            "definition": "出租人在租赁期间需承担的费用项目，具体内容在费用承担实体中记录",
            "head_entity_type": "出租人",
            "tail_entity_type": "费用承担",
            "triggers": ["水费", "电费", "燃气费", "物业费", "承担", "费用"],
            "examples": [
                "以下费用由甲方支付：1.供暖费；2.物业管理费。"
            ]
        },
        {
            "relation": "出租人维修责任",
            "definition": "出租人承担的房屋及设施维修义务，具体内容在维修责任实体中记录",
            "head_entity_type": "出租人",
            "tail_entity_type": "维修责任",
            "triggers": ["维修", "修理费用", "维修责任", "养护"],
            "examples": [
                "正常的房屋修理费用由甲方承担。"
            ]
        },
        {
            "relation": "承租人维修责任",
            "definition": "承租人承担的房屋及设施维修义务，具体内容在维修责任实体中记录",
            "head_entity_type": "承租人",
            "tail_entity_type": "维修责任",
            "triggers": ["维修", "修理费用", "维修责任", "养护"],
            "examples": [
                "因乙方管理使用不善造成房屋及其相连设备的损失和维修费用，由乙方承担并责任赔偿损失。"
            ]
        },
        {
            "relation": "出租人违约责任",
            "definition": "出租人违反合同约定时应承担的责任，具体内容在违约责任实体中记录",
            "head_entity_type": "出租人",
            "tail_entity_type": "违约责任",
            "triggers": ["违约金", "违约", "违反本合同", "承担责任"],
            "examples": [
                "租赁期间双方任何一方违反本合同规定，须向对方交纳壹千元作为违约金。",
                "任何一方违反本合同的规定，按年度须向对方交纳三个月租金作为违约金。"
            ]
        },
        {
            "relation": "承租人违约责任",
            "definition": "承租人违反合同约定时应承担的责任，具体内容在违约责任实体中记录",
            "head_entity_type": "承租人",
            "tail_entity_type": "违约责任",
            "triggers": ["违约金", "违约", "违反本合同", "承担责任"],
            "examples": [
                "租赁期间双方任何一方违反本合同规定，须向对方交纳壹千元作为违约金。"
            ]
        },
        {
            "relation": "转租约定",
            "definition": "承租人是否有权转租房屋，具体约定在转租约定实体中记录",
            "head_entity_type": "承租人",
            "tail_entity_type": "转租约定",
            "triggers": ["转租", "转让", "转借", "转让他人"],
            "examples": [
                "未经甲方书面同意，乙方擅自将房屋转租、转让或转借的，甲方可以终止合同。",
                "合同期内，乙方如不能再继续经营时，可转让他人经营。"
            ]
        },
        {
            "relation": "约定房屋用途",
            "definition": "承租人使用房屋的用途，具体描述在房屋用途实体中记录",
            "head_entity_type": "承租人",
            "tail_entity_type": "房屋用途",
            "triggers": ["用途", "租赁用途", "房屋用途", "使用"],
            "examples": [
                "该房屋用途为租赁住房。",
                "除双方另有约定外，乙方不得任意改变房屋用途。"
            ]
        },
        {
            "relation": "交付房屋日期",
            "definition": "出租人将房屋交付给承租人的日期，具体日期在交付日期实体中记录",
            "head_entity_type": "出租人",
            "tail_entity_type": "交付日期",
            "triggers": ["交付", "交付房屋", "交房", "交付期限"],
            "examples": [
                "甲方应于本合同生效之日起5日内，将该房屋交付给乙方。",
                "甲方应于2021年2月28日前将该房屋交付给乙方。"
            ]
        },
        {
            "relation": "确认设施清单",
            "definition": "承租人确认房屋内的设施物品清单，具体内容在设施物品清单实体中记录",
            "head_entity_type": "承租人",
            "tail_entity_type": "设施物品清单",
            "triggers": ["设施", "物品清单", "家具", "家电"],
            "examples": [
                "双方确认房屋内设施物品清单见附件。",
                "家具清单：床、衣柜、空调等。"
            ]
        }
    ],
    "note": "抽取时，如果文档中未提及某实体或关系，则忽略。关系方向严格按照头尾实体类型定义。对于费用承担、维修责任、违约责任等可能由双方承担的情况，已拆分为独立的出租人/承租人关系，抽取时根据文本描述选择对应关系。房屋地址、设施物品清单等实体通过对应关系与承租人连接。"
}