{
    "contract_type": "实习合同",
    "description": "本模板定义了实习合同知识抽取的实体类型和关系类型，每个关系明确了头实体类型和尾实体类型，用于指导三元组（头实体-关系-尾实体）的抽取。",
    "entities": [
        "用人单位",
        "实习生",
        "实习岗位",
        "实习报酬",
        "实习起止日期",
        "工作地点",
        "工作时间",
        "保密条款",
        "学校",
        "保险"
    ],
    "relations": [
        {
            "relation": "实习单位",
            "definition": "实习生在该用人单位进行实习",
            "head_entity_type": "实习生",
            "tail_entity_type": "用人单位",
            "triggers": ["实习", "在...实习", "任职", "工作于"],
            "examples": [
                "乙方在甲方进行实习",
                "乙方于甲方单位实习"
            ]
        },
        {
            "relation": "获得报酬",
            "definition": "实习生从用人单位获得实习期间的劳动报酬",
            "head_entity_type": "实习生",
            "tail_entity_type": "实习报酬",
            "triggers": ["报酬", "实习补助", "工资", "薪资", "支付", "实习费"],
            "examples": [
                "甲方按以下标准支付乙方实习报酬：1500元/月",
                "支付乙方实习期间工资实习期2500元/月"
            ]
        },
        {
            "relation": "约定实习期限",
            "definition": "用人单位与实习生约定实习的开始日期和结束日期",
            "head_entity_type": "实习生",
            "tail_entity_type": "实习起止日期",
            "triggers": ["实习时间", "期限", "自", "至", "实习期"],
            "examples": [
                "期限为2024年08月12日至2024年09月11日止",
                "实习时间自2024年9月1日至2025年8月30日"
            ]
        },
        {
            "relation": "工作时长",
            "definition": "实习生在用人单位的每日工作时长",
            "head_entity_type": "实习生",
            "tail_entity_type": "工作时间",
            "triggers": ["工作时间", "小时/天", "自", "至"],
            "examples": [
                "甲方安排乙方实习学生的工作时间原则上不超过8小时/天",
                "工作时间为9：00-12：00，14：00-17：00"
            ]
        },
        {
            "relation": "工作岗位",
            "definition": "用人单位为实习生分配具体工作岗位",
            "head_entity_type": "实习生",
            "tail_entity_type": "实习岗位",
            "triggers": ["岗位", "工作", "安排", "实习岗位", "从事"],
            "examples": [
                "乙方实习工作名称：测试实习生",
                "安排乙方在本单位从事工程助理岗位"
            ]
        },
        {
            "relation": "工作地点",
            "definition": "实习生的实习工作地点",
            "head_entity_type": "实习生",
            "tail_entity_type": "工作地点",
            "triggers": ["工作地点", "实习地点", "地点", "位于"],
            "examples": [
                "乙方实习工作地点为佛山市南海区狮山镇",
                "工作地点在广州市天河区体育西路"
            ]
        },
        {
            "relation": "购买保险",
            "definition": "用人单位为实习生购买人身意外伤害等保险",
            "head_entity_type": "用人单位",
            "tail_entity_type": "保险",
            "triggers": ["意外伤害保险", "人身团体意外险", "办理保险", "购买保险"],
            "examples": [
                "甲方负责为实习学生在进入工作岗位实习开始前办理好意外伤害保险",
                "并为实习生购买人身团体意外险"
            ]
        }
    ],
    "note": "抽取时，如果文档中未提及某实体或关系，则忽略。关系方向严格按照头尾实体类型定义，例如（实习生，获得报酬，实习报酬）表示实习生获得一定金额的报酬，金额细节应在实习报酬实体中体现。对于未在关系中直接关联的实体（如学校、工作地点），可单独提取作为节点，或根据上下文与其他实体建立隐含关系（如实习生-就读于-学校）。"
}